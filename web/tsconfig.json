{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@pacifica/core/*": ["../src/core/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../src/core/patterns/backtest.ts",
    "../src/core/patterns/candles.ts",
    "../src/core/patterns/types.ts",
    "../src/core/patterns/matcher.ts",
    "../src/core/patterns/loader.ts",
    "../src/core/intelligence/schema.ts"
  ],
  "exclude": ["node_modules"]
}
