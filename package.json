{
  "name": "pacifica-cli",
  "version": "0.1.0",
  "description": "Agent-native trading terminal for Pacifica DEX",
  "type": "module",
  "bin": {
    "pacifica": "dist/cli.js",
    "pacifica-cli": "dist/cli.js",
    "pacifica-mcp": "dist/mcp.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "pacifica",
    "dex",
    "trading",
    "cli",
    "mcp",
    "terminal"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fastify": "^5.8.4",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
